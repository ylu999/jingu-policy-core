{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jingu.dev/schemas/rpp/rpp.schema.json",
  "title": "RPPRecord",
  "description": "Authoritative contract for an RPP (Reasoning + Policy + Provenance) record.",
  "type": "object",
  "required": ["call_id", "steps", "response"],
  "additionalProperties": false,
  "properties": {
    "call_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "call_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "steps": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/definitions/Step"
      }
    },
    "response": {
      "$ref": "#/definitions/ResponseObject"
    }
  },
  "definitions": {
    "EvidenceRef": {
      "type": "object",
      "required": ["type", "source", "locator", "supports"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "evidence"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "supports": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "RuleRef": {
      "type": "object",
      "required": ["type", "rule_id", "supports"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "rule"
        },
        "rule_id": {
          "type": "string",
          "pattern": "^[A-Z]+-[0-9]+$"
        },
        "supports": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "MethodRef": {
      "type": "object",
      "required": ["type", "method_id", "supports"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "method"
        },
        "method_id": {
          "type": "string",
          "pattern": "^[A-Z]+-[0-9]+$"
        },
        "supports": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "Reference": {
      "oneOf": [
        { "$ref": "#/definitions/EvidenceRef" },
        { "$ref": "#/definitions/RuleRef" },
        { "$ref": "#/definitions/MethodRef" }
      ]
    },
    "Step": {
      "type": "object",
      "required": ["stage", "content", "references"],
      "additionalProperties": false,
      "properties": {
        "stage": {
          "type": "string",
          "enum": ["interpretation", "reasoning", "decision", "action"]
        },
        "content": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/Reference"
          }
        },
        "method_refs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MethodRef"
          }
        },
        "uncertainties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ResponseObject": {
      "type": "object",
      "required": ["content", "references"],
      "additionalProperties": false,
      "properties": {
        "content": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/Reference"
          }
        }
      }
    }
  }
}
