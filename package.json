{
  "name": "jingu-policy-core",
  "version": "0.1.0",
  "description": "Engineering discipline policy library for Jingu Trust-Gate",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./rpp": {
      "import": "./dist/src/rpp/rpp.types.js",
      "require": "./dist/src/rpp/rpp.types.js",
      "types": "./dist/src/rpp/rpp.types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test 'dist/tests/**/*.test.js' 'dist/tests/*.test.js' 'dist/src/**/*.test.js'",
    "test:src": "npx tsc --noEmit",
    "demo:resolver": "npm run build && node dist/demo/policy-resolver-demo.js",
    "demo:brief": "npm run build && node dist/demo/brief-builder-demo.js",
    "demo:gates": "npm run build && node dist/demo/gate-engine-demo.js"
  },
  "dependencies": {
    "jingu-protocol": "file:../jingu-protocol"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
